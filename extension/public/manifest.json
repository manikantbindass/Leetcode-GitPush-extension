{
  "manifest_version": 3,
  "name": "LeetCode AI Sync",
  "version": "1.0.0",
  "description": "Auto-detect LeetCode accepted submissions, generate AI solutions in 14+ languages, and push to GitHub automatically.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "LeetCode AI Sync"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "src/content/injected.js", "*.js", "*.css"],
      "matches": ["https://leetcode.com/*", "<all_urls>"]
    }
  ],
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://github.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost/*"
  ]
}
