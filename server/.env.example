# GitHub OAuth App credentials
# Register your OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# Comma-separated list of allowed CORS origins
# Replace with your actual Chrome Extension ID from chrome://extensions/
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID_HERE

# Server port (default: 3001)
PORT=3001
